# ─────────────────────────────────────────────────────────────
#  EcoCycleHUB — Frontend Environment Variables (Vite)
#  Copy this file to .env and fill in your real values.
#  All variables MUST start with VITE_ to be exposed to the browser.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────
# Local development:
#   VITE_BACKEND_URL=http://localhost:4000
# Production — replace with your actual Render backend URL:
#   VITE_BACKEND_URL=https://ecocyclehub.onrender.com
VITE_API_URL=https://your-backend-name.onrender.com

# ── Firebase (Phone Auth / Google Auth) ───────────────────────
# Get from: https://console.firebase.google.com
#   → Your Project → Project Settings → Your Apps → Web App → Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
